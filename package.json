{
  "name": "height_workout_infinitrix",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:watch\" \"npm:serve\"",
    "watch": "esbuild src/index.ts --bundle --platform=node --format=cjs --sourcemap --outfile=dist/index.js --watch",
    "serve": "nodemon --watch dist --delay 100ms dist/index.js",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --minify --outfile=dist/index.js",
    "start": "node dist/index.js"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.2",
    "nodemon": "^3.1.11",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "fs-extra": "^11.3.4",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.16.0",
    "pdf-to-png-converter": "^3.14.0",
    "pdf2pic": "^3.2.0",
    "sharp": "^0.34.5"
  }
}
